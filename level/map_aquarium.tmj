    {
      "name": "deadlineMinute",
      "type": "int",
      "value": 0
    },
    {
      "name": "rules",
      "type": "string",
      "value": "[{\"id\":\"R1\",\"num\":1,\"text\":\"维护期间，请保持浅海区的水槽照明常亮。如果灯光闪烁，请在10秒内找到备用电源开关。\",\"type\":\"TRUE\",\"mark\":\"unknown\"},{\"id\":\"R2\",\"num\":2,\"text\":\"海底隧道是绝对安全的。如果你觉得玻璃外有东西在看着你，那只是错觉，请直视它并快速走过。\",\"type\":\"FALSE\",\"mark\":\"unknown\"},{\"id\":\"R3\",\"num\":3,\"text\":\"深海巨兽区目前没有展出任何生物。如果水槽内出现巨大发光体，请立刻按下墙上的红色警报按钮。\",\"type\":\"TRAP\",\"mark\":\"unknown\"},{\"id\":\"R4\",\"num\":4,\"text\":\"遇到穿着潜水服但没有携带氧气瓶的人，请向他提供你背包里的\\\"特制鱼饵\\\"。\",\"type\":\"CONDITIONAL\",\"mark\":\"unknown\"},{\"id\":\"R5\",\"num\":5,\"text\":\"水泵控制室的温度必须保持在20度。如果温度计显示低于15度，请躲进储物柜，直到听到三声敲门声再出来。\",\"type\":\"TRUE\",\"mark\":\"unknown\"},{\"id\":\"R6\",\"num\":6,\"text\":\"如果听到水槽里传来人类的呼救声，请无视。我们的水槽是隔音的。\",\"type\":\"TRUE\",\"mark\":\"unknown\"}]"
    }
  ],
