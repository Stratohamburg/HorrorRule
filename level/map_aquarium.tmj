  "properties": [
    {
      "name": "name",
      "type": "string",
      "value": "蓝海市极地海洋馆"
    },
    {
      "name": "timeLimit",
      "type": "int",
      "value": 0
    },
    {
      "name": "gameClock",
      "type": "int",
      "value": 1320
    },
    {
